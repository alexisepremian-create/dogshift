# DogShift — env vars template.
# Copy to .env.local and fill in the real values. Never commit secrets.

# ── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...?sslmode=require
DIRECT_URL=postgresql://...?sslmode=require

# ── App URL (used by absolute links in emails, OAuth callbacks, etc.) ────────
NEXT_PUBLIC_APP_URL=https://www.dogshift.ch

# ── Auth.js v5 (PR 1) ────────────────────────────────────────────────────────
# Generate with: `npx auth secret`
AUTH_SECRET=
# Reuse the existing Google OAuth client (same project as Clerk).
# Add the new redirect URI in Google Cloud Console BEFORE PR 2:
#   https://www.dogshift.ch/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Required when Auth.js runs behind Cloudflare or any other proxy.
AUTH_TRUST_HOST=true

# ── Native Google Sign-In (iOS app) ──────────────────────────────────────────
# Google blocks OAuth in embedded WebViews, so the iOS app uses the native SDK
# (@capgo/capacitor-social-login) → ID token → verified by the "google-native"
# provider in auth.ts. Create an "iOS" OAuth client in Google Cloud Console
# (bundle id ch.dogshift.app); these client IDs are NOT secret.
# Server-side: list of accepted ID-token audiences (iOS client id).
AUTH_GOOGLE_IOS_ID=
# Client-side (baked into the web bundle, public): used by SocialLogin.initialize().
#   - WEB = the same OAuth web client as AUTH_GOOGLE_ID (becomes the iOSServerClientId
#     so the returned idToken's audience is the web client, server-verifiable).
#   - IOS = the new iOS OAuth client id.
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ── Admin gating ─────────────────────────────────────────────────────────────
# Comma-separated email whitelist. Even with role=ADMIN in DB, the middleware
# also requires the user's email to match this list (ceinture + bretelles).
ADMIN_EMAILS=alexis.epremian@gmail.com
# 12h cookie code used by /admin/* gate.
HOST_ADMIN_CODE=

# ── Clerk (still used in PR 1; removed in PR 3) ──────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Email (Resend primary, SMTP fallback) ────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=DogShift <no-reply@dogshift.ch>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Stripe Connect ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Maps ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPTILER_KEY=

# ── Pilot mode ───────────────────────────────────────────────────────────────
PILOT_MODE=true
PILOT_ADMIN_CODE=

# ── Misc ─────────────────────────────────────────────────────────────────────
CONTRACT_TOKEN_SECRET=
VONAGE_API_KEY=
VONAGE_API_SECRET=
SITE_PASSWORD=
DOGSHIFT_ADMIN_SECRET=
