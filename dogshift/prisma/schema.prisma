// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  SITTER
}

enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING_ACCEPTANCE
  PAID
  CONFIRMED
  PAYMENT_FAILED
  CANCELLED
  REFUNDED
  REFUND_FAILED
}

enum BookingPayoutMethod {
  STRIPE
  MANUAL
}

enum BookingPayoutStatus {
  PENDING
  PAID
}

enum FinanceActorType {
  SYSTEM
  ADMIN
  STRIPE
}

enum NotificationType {
  newMessages
  newBookingRequest
  paymentReceived
  bookingConfirmed
  bookingReminder
}

enum InviteCodeType {
  single_use
  master
}

enum VerificationStatus {
  not_verified
  pending
  approved
  rejected
}

enum ServiceType {
  PROMENADE
  DOGSITTING
  PENSION
}

enum AvailabilityStatus {
  AVAILABLE
  ON_REQUEST
  UNAVAILABLE
}

enum SitterApplicationStatus {
  PENDING
  CONTACTED
  ACCEPTED
  ACTIVATED
  REJECTED
}

enum SitterLifecycleStatus {
  application_received
  selected
  contract_to_sign
  contract_signed
  activated
}

enum AdminNoteTargetType {
  USER
  BOOKING
  PILOT_SITTER_APPLICATION
  SITTER_PROFILE
}

enum ContractAmendmentStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum ServiceCostType {
  hosting
  db
  payment
  email
  auth
  other
}

enum ServiceCostBillingType {
  fixed
  variable
}

model User {
  id              String    @id @default(cuid())
  clerkUserId     String?   @unique
  email           String    @unique
  name            String?
  image           String?
  phone           String?   @db.VarChar(20)
  emailVerified   DateTime?
  passwordHash    String?
  hostProfileJson String?
  role            Role      @default(OWNER)
  sitterId        String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  bookings       Booking[] @relation("UserBookings")
  sitterBookings Booking[] @relation("SitterBookings")

  ownerConversations  Conversation[] @relation("OwnerConversations")
  sitterConversations Conversation[] @relation("SitterConversations")
  sentMessages        Message[]

  sitterProfile SitterProfile?

  sitterApplications SitterApplication[]

  notifications Notification[]

  reviewsWritten  Review[] @relation("ReviewOwner")
  reviewsReceived Review[] @relation("ReviewSitter")

  availabilities Availability[] @relation("SitterAvailabilities")

  availabilityRules      AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  serviceConfigs         ServiceConfig[]
}

model Notification {
  id String @id @default(cuid())

  userId String
  type   NotificationType

  title    String
  body     String?
  entityId String?
  url      String?
  metadata Json?

  idempotencyKey String

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model InviteCode {
  id String @id @default(cuid())

  code      String         @unique
  type      InviteCodeType
  usedAt    DateTime?
  expiresAt DateTime?
  note      String?

  createdAt DateTime @default(now())
}

model SitterApplication {
  id String @id @default(cuid())

  userId String
  data   Json

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PilotSitterApplication {
  id String @id @default(cuid())

  firstName String
  lastName  String
  city      String
  email     String
  phone     String

  age Int?

  experienceText   String
  hasDogExperience Boolean
  motivationText   String
  availabilityText String

  consentInterview Boolean
  consentPrivacy   Boolean

  // Structured fields for automated scoring (n8n). Nullable / defaulted for
  // backward compatibility with legacy pilot applications.
  npa                       String?
  cityOther                 String?
  linkAnimalProfession      String?
  linkAnimalProfessionOther String?
  gardeExperienceLevel      String?
  availabilityStructured    Json?
  gardeTypes                String[] @default([])
  dogSizes                  String[] @default([])
  housingType               String?
  housingTypeOther          String?
  otherAnimals              Json?
  otherAnimalsDogCount      Int?
  hasCarLicense             Boolean?
  allergies                 String?

  status SitterApplicationStatus @default(PENDING)

  // Per-candidate Calendly link used by the "Accepté" flow. When set, clicking
  // "Accepté" in the admin UI sends the same HIGH email the n8n scoring
  // workflow would have sent, pointing to this link.
  calendlyLink String?

  // Set the first time the "HIGH / interview" email has been delivered to the
  // candidate — whether by the n8n scoring workflow (source="n8n") or by a
  // manual admin click on "Accepté" (source="admin"). Used to dedupe and to
  // let the UI warn before re-sending.
  acceptedEmailSentAt DateTime?
  acceptedEmailSource String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  referrer       String?
  userAgent      String?
  ip             String?
  idempotencyKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([email, createdAt])
  @@index([city, status])
  @@unique([email, idempotencyKey])
}

model AdminNote {
  id String @id @default(cuid())

  targetType AdminNoteTargetType
  targetId   String

  body String

  authorClerkUserId String?
  authorUserId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([authorClerkUserId, createdAt])
}

model SitterProfile {
  id String @id @default(cuid())

  userId   String @unique
  sitterId String @unique

  published   Boolean   @default(false)
  publishedAt DateTime?

  displayName String?
  city        String?
  postalCode  String?
  bio         String?
  avatarUrl   String?

  lat Float?
  lng Float?

  services Json?
  pricing  Json?
  dogSizes Json?

  termsAcceptedAt   DateTime?
  termsVersion      String?
  profileCompletion Int       @default(0)

  lifecycleStatus        SitterLifecycleStatus @default(application_received)
  contractVersion        String?
  contractAcceptedAt     DateTime?
  contractSignerName     String?
  contractSignedAt       DateTime?
  contractSignatureValue String?
  contractSnapshot       Json?
  contractSignedPdfUrl  String?
  contractAccessTokenHash   String?
  contractAccessTokenVersion String?
  contractAccessTokenIssuedAt DateTime?
  contractAccessTokenExpiresAt DateTime?
  contractAccessTokenUsedAt DateTime?
  activationCodeHash      String?   @unique
  activationCodeIssuedAt  DateTime?
  activationCodeExpiresAt DateTime?
  activationCodeUsedAt    DateTime?
  activatedAt             DateTime?

  verificationStatus      VerificationStatus @default(not_verified)
  idDocumentUrl           String?
  selfieUrl               String?
  verificationSubmittedAt DateTime?
  verificationReviewedAt  DateTime?
  verificationNotes       String?

  verificationAccessLogs VerificationAccessLog[]
  contractAmendmentAcceptances SitterContractAmendmentAcceptance[]

  stripeAccountId               String?
  stripeAccountStatus           String?
  stripeOnboardingCompletedAt   DateTime?

  lastMinuteEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([published])
  @@index([city])
  @@index([postalCode])
  @@index([verificationStatus])
}

model VerificationAccessLog {
  id String @id @default(cuid())

  sitterProfileId String
  sitterId        String

  action  String
  fileKey String?

  adminClerkUserId String?
  userAgent        String?

  createdAt DateTime @default(now())

  sitterProfile SitterProfile @relation(fields: [sitterProfileId], references: [id], onDelete: Cascade)

  @@index([sitterProfileId, createdAt])
  @@index([sitterId, createdAt])
}

model ContractAmendment {
  id String @id @default(cuid())

  title   String
  content String
  version String @unique

  status      ContractAmendmentStatus @default(INACTIVE)
  isActive    Boolean                 @default(false)
  activatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  acceptances SitterContractAmendmentAcceptance[]

  @@index([status, createdAt])
  @@index([isActive, createdAt])
  @@index([createdAt])
}

model ServiceCost {
  id String @id @default(cuid())

  name      String
  type      ServiceCostType
  costType  ServiceCostBillingType
  monthlyCost Float
  notes     String?
  active    Boolean @default(true)
  estimatedCostPerBooking Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
}

model SitterContractAmendmentAcceptance {
  id String @id @default(cuid())

  amendmentId     String
  sitterProfileId String

  amendmentVersion String
  amendmentTitle   String
  amendmentContent String
  acceptedAt       DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  amendment     ContractAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)
  sitterProfile SitterProfile     @relation(fields: [sitterProfileId], references: [id], onDelete: Cascade)

  @@unique([amendmentId, sitterProfileId])
  @@index([sitterProfileId, acceptedAt])
  @@index([amendmentId, acceptedAt])
}

model Booking {
  id String @id @default(cuid())

  userId   String
  sitterId String

  service   String?
  startDate DateTime?
  endDate   DateTime?

  serviceType ServiceType?
  startAt     DateTime?
  endAt       DateTime?

  message String?

  status            BookingStatus @default(PENDING_PAYMENT)
  canceledAt        DateTime?
  amount            Int
  currency          String        @default("chf")
  platformFeeAmount Int

  stripeSessionId       String?
  stripePaymentIntentId String?
  stripeChargeId        String?

  stripeTransferId            String?
  stripeApplicationFeeAmount  Int           @default(0)
  stripeProcessingFeeAmount   Int           @default(0)
  sitterPayoutAmount          Int?
  payoutReleasedAt            DateTime?
  payoutMethod                BookingPayoutMethod @default(STRIPE)
  payoutStatus                BookingPayoutStatus @default(PENDING)
  paidAt                      DateTime?

  stripeRefundId String?
  refundedAt     DateTime?

  reviewRequestEmailSentAt DateTime?

  lastMinuteSmsSentAt DateTime?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)
  sitter User @relation("SitterBookings", fields: [sitterId], references: [sitterId], onDelete: Restrict)

  conversations Conversation[] @relation("BookingConversations")

  review Review?
  financeEvents BookingFinanceEvent[]

  @@index([userId])
  @@index([sitterId])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
}

model BookingFinanceEvent {
  id String @id @default(cuid())

  bookingId String
  eventType String
  message   String

  payoutMethod BookingPayoutMethod?
  payoutStatus BookingPayoutStatus?

  amount   Int?
  currency String?

  stripeChargeId    String?
  stripeTransferId  String?
  stripePaymentIntentId String?

  metadata Json?

  actorType FinanceActorType?
  actorId   String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([eventType, createdAt])
  @@index([actorType, createdAt])
}

model Review {
  id String @id @default(cuid())

  bookingId String @unique
  ownerId   String
  sitterId  String

  rating  Int
  comment String?
  anonymous Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  owner   User    @relation("ReviewOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sitter  User    @relation("ReviewSitter", fields: [sitterId], references: [sitterId], onDelete: Restrict)

  @@index([sitterId, createdAt])
  @@index([ownerId, createdAt])
}

model Availability {
  id String @id @default(cuid())

  sitterId String
  dateKey String
  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sitter User @relation("SitterAvailabilities", fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@unique([sitterId, dateKey])
  @@index([sitterId, dateKey])
}

model AvailabilityRule {
  id String @id @default(cuid())

  sitterId   String
  serviceType ServiceType
  dayOfWeek  Int
  startMin   Int
  endMin     Int
  status     AvailabilityStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sitter User @relation(fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@index([sitterId, serviceType, dayOfWeek])
  @@index([sitterId, serviceType])
}

model AvailabilityException {
  id String @id @default(cuid())

  sitterId  String
  serviceType ServiceType
  date      DateTime @db.Date
  startMin  Int
  endMin    Int
  status    AvailabilityStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sitter User @relation(fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@index([sitterId, serviceType, date])
  @@index([sitterId, serviceType])
}

model AvailabilityAuditLog {
  id String @id @default(cuid())

  sitterId      String
  actorUserId   String

  action      String
  serviceType  ServiceType?
  dateKey      String?
  payloadSummary Json?

  createdAt DateTime @default(now())

  @@index([sitterId, createdAt])
  @@index([sitterId, serviceType, createdAt])
}

model ServiceConfig {
  id String @id @default(cuid())

  sitterId     String
  serviceType  ServiceType
  enabled      Boolean @default(true)

  slotStepMin      Int
  minDurationMin   Int
  maxDurationMin   Int
  leadTimeMin      Int
  bufferBeforeMin  Int
  bufferAfterMin   Int

  lastMinuteEnabled Boolean @default(false)

  overnightRequired Boolean @default(false)
  checkInStartMin   Int?
  checkInEndMin     Int?
  checkOutStartMin  Int?
  checkOutEndMin    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sitter User @relation(fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@unique([sitterId, serviceType])
  @@index([sitterId])
  @@index([serviceType])
}

model Conversation {
  id String @id @default(cuid())

  ownerId   String
  sitterId  String
  bookingId String?

  lastMessageAt      DateTime?
  lastMessagePreview String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User     @relation("OwnerConversations", fields: [ownerId], references: [id], onDelete: Cascade)
  sitter  User     @relation("SitterConversations", fields: [sitterId], references: [sitterId], onDelete: Restrict)
  booking Booking? @relation("BookingConversations", fields: [bookingId], references: [id], onDelete: SetNull)

  messages Message[]

  @@unique([ownerId, sitterId])
  @@index([ownerId])
  @@index([sitterId])
  @@index([bookingId])
  @@index([lastMessageAt])
}

model Message {
  id String @id @default(cuid())

  conversationId String
  senderId       String
  body           String
  readAt         DateTime?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Immutable audit trail for legal / dispute purposes.
/// Records every critical action on the platform with actor, target and timestamp.
/// Never delete rows — only append. No PII in metadata (use IDs only).
model AuditLog {
  id String @id @default(cuid())

  /// e.g. "booking.created", "booking.paid", "booking.cancelled",
  ///      "sitter.approved", "sitter.rejected", "account.deleted"
  action String

  /// "admin" | "user" | "system" | "stripe"
  actorType String

  /// Clerk user ID (admin/user), "system" or "stripe"
  actorId String?

  /// Primary key of the affected entity (booking ID, user ID, etc.)
  targetId String?

  /// "BOOKING" | "USER" | "SITTER_PROFILE" | "APPLICATION"
  targetType String?

  /// Additional context: amounts (in cents), old/new status, payment intent ID…
  /// Never store email, name, phone or other PII here.
  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetId, targetType])
  @@index([actorId, createdAt])
}

/// Singleton row `id = "global"` — platform-wide toggles (maintenance, etc.).
model PlatformSettings {
  id                 String   @id
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Persistent memory for autonomous agents (Maestro & sub-agents).
/// Stores conversation history, context, and state between runs.
model AgentMemory {
  id        String   @id @default(cuid())

  /// Agent name: "maestro", "booking_agent", "dispo_agent", "payment_agent"…
  agentName String

  /// Session ID to group related interactions
  sessionId String

  /// Role: "system" | "user" | "assistant" | "tool_call" | "tool_result"
  role String

  /// The actual message content (JSON stringified for complex objects)
  content String

  /// Token count for context window management
  tokenCount Int @default(0)

  /// Metadata for filtering (bookingId, sitterId, userId, etc.)
  metadata Json?

  createdAt DateTime @default(now())

  @@index([agentName, sessionId, createdAt])
  @@index([agentName, createdAt])
  @@index([sessionId, createdAt])
}

/// Logs every action taken by an autonomous agent. Append only.
model AgentLog {
  id        String   @id @default(cuid())

  /// "maestro" | "booking_agent" | "dispo_agent" | "payment_agent" | "notification_agent" | "supervision_agent"
  agentName String

  /// "webhook_received" | "intent_determined" | "sub_agent_called" | "api_call" | "error" | "success"
  actionType String

  /// What the agent did (human readable)
  summary String

  /// Full details (request, response, error stack…)
  details Json?

  /// Related entities (booking ID, user ID, sitter ID…)
  targetId String?

  /// Duration in ms
  durationMs Int?

  /// Status: "success" | "error" | "running"
  status String @default("success")

  createdAt DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([actionType, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

/// Tracks scheduled or running tasks for autonomous agents.
model AgentTask {
  id        String   @id @default(cuid())

  /// "maestro" | "booking_agent" | "dispo_agent" | …
  agentName String

  /// "scheduled" | "running" | "completed" | "failed" | "cancelled"
  status String @default("scheduled")

  /// Human readable task description
  title String

  /// Full task definition / parameters
  payload Json?

  /// Result of the task execution
  result Json?

  /// Error message if failed
  errorMessage String?

  /// How many times it has been retried
  retryCount Int @default(0)

  /// Max retries before marking as failed
  maxRetries Int @default(3)

  /// When the task should be executed
  scheduledAt DateTime?

  /// When the task started
  startedAt DateTime?

  /// When the task completed/failed
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentName, status, scheduledAt])
  @@index([status, scheduledAt])
  @@index([createdAt])
}
