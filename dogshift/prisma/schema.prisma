generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String?
  image                  String?
  role                   Role                    @default(OWNER)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  emailVerified          DateTime?
  sitterId               String?                 @unique
  passwordHash           String?
  hostProfileJson        String?
  clerkUserId            String?                 @unique
  phone                  String?                 @db.VarChar(20)
  accounts               Account[]
  availabilities         Availability[]          @relation("SitterAvailabilities")
  availabilityExceptions AvailabilityException[]
  availabilityRules      AvailabilityRule[]
  sitterBookings         Booking[]               @relation("SitterBookings")
  bookings               Booking[]               @relation("UserBookings")
  ownerConversations     Conversation[]          @relation("OwnerConversations")
  sitterConversations    Conversation[]          @relation("SitterConversations")
  dogProfiles            DogProfile[]
  sentMessages           Message[]
  notifications          Notification[]
  reviewsWritten         Review[]                @relation("ReviewOwner")
  reviewsReceived        Review[]                @relation("ReviewSitter")
  serviceConfigs         ServiceConfig[]
  sessions               Session[]
  sitterApplications     SitterApplication[]
  sitterProfile          SitterProfile?
  pushSubscriptions      PushSubscription[]
  nativePushTokens       NativePushToken[]
  matchMessagesSent      MatchMessage[]          @relation("MatchMessagesSent")
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  type           NotificationType
  title          String
  body           String?
  entityId       String?
  url            String?
  metadata       Json?
  idempotencyKey String
  createdAt      DateTime         @default(now())
  readAt         DateTime?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model InviteCode {
  id        String         @id @default(cuid())
  code      String         @unique
  type      InviteCodeType
  usedAt    DateTime?
  expiresAt DateTime?
  note      String?
  createdAt DateTime       @default(now())
}

model SitterApplication {
  id        String   @id @default(cuid())
  userId    String
  data      Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PilotSitterApplication {
  id                        String                  @id @default(cuid())
  firstName                 String
  lastName                  String
  city                      String
  email                     String
  phone                     String
  age                       Int?
  experienceText            String
  hasDogExperience          Boolean
  motivationText            String
  availabilityText          String
  consentInterview          Boolean
  consentPrivacy            Boolean
  status                    SitterApplicationStatus @default(PENDING)
  utmSource                 String?
  utmMedium                 String?
  utmCampaign               String?
  utmContent                String?
  utmTerm                   String?
  referrer                  String?
  userAgent                 String?
  ip                        String?
  idempotencyKey            String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  npa                       String?
  cityOther                 String?
  linkAnimalProfession      String?
  linkAnimalProfessionOther String?
  gardeExperienceLevel      String?
  availabilityStructured    Json?
  gardeTypes                String[]                @default([])
  dogSizes                  String[]                @default([])
  housingType               String?
  housingTypeOther          String?
  otherAnimals              Json?
  otherAnimalsDogCount      Int?
  hasCarLicense             Boolean?
  allergies                 String?
  calendlyLink              String?
  acceptedEmailSentAt       DateTime?
  acceptedEmailSource       String?
  /// Postal address (rue + numéro, e.g. "Rue du Lac 35"). Combined with city + npa
  /// at display time. Required by the new sitter form so we can compute travel
  /// fees and ship the contract PDF — nullable in schema for backward compat
  /// with applications submitted before this field existed.
  address                   String?

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([email, createdAt])
  @@index([city, status])
}

model AdminNote {
  id                String              @id @default(cuid())
  targetType        AdminNoteTargetType
  targetId          String
  body              String
  authorClerkUserId String?
  authorUserId      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([targetType, targetId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([authorClerkUserId, createdAt])
}

model SitterProfile {
  id                           String                              @id @default(cuid())
  userId                       String                              @unique
  sitterId                     String                              @unique
  published                    Boolean                             @default(false)
  publishedAt                  DateTime?
  displayName                  String?
  city                         String?
  postalCode                   String?
  bio                          String?
  avatarUrl                    String?
  lat                          Float?
  lng                          Float?
  services                     Json?
  pricing                      Json?
  dogSizes                     Json?
  createdAt                    DateTime                            @default(now())
  updatedAt                    DateTime                            @updatedAt
  termsAcceptedAt              DateTime?
  termsVersion                 String?
  profileCompletion            Int                                 @default(0)
  idDocumentUrl                String?
  selfieUrl                    String?
  verificationNotes            String?
  verificationReviewedAt       DateTime?
  verificationStatus           VerificationStatus                  @default(not_verified)
  verificationSubmittedAt      DateTime?
  stripeAccountId              String?
  stripeAccountStatus          String?
  stripeOnboardingCompletedAt  DateTime?
  lifecycleStatus              SitterLifecycleStatus               @default(application_received)
  contractVersion              String?
  contractAcceptedAt           DateTime?
  contractSignerName           String?
  contractSignedAt             DateTime?
  contractSignatureValue       String?
  contractSnapshot             Json?
  activationCodeHash           String?                             @unique
  activationCodeIssuedAt       DateTime?
  activationCodeUsedAt         DateTime?
  activatedAt                  DateTime?
  contractAccessTokenHash      String?
  contractAccessTokenIssuedAt  DateTime?
  contractAccessTokenExpiresAt DateTime?
  contractAccessTokenUsedAt    DateTime?
  lastMinuteEnabled            Boolean                             @default(false)
  contractAccessTokenVersion   String?
  contractSignedPdfUrl         String?
  activationCodeExpiresAt      DateTime?
  address                      String?
  /// @deprecated — kept for backward compat during migration. Use capacityPlaces + accepts* instead.
  maxDogsBySize                Json?
  /// Pension home photo verification
  /// Status: not_submitted | pending | ai_reviewing | ai_approved | ai_rejected | approved | rejected | legacy_pending
  pensionVerifStatus           String                              @default("not_submitted")
  pensionPhotoUrls             Json?
  pensionPhotoSubmittedAt      DateTime?
  pensionPhotoReviewedAt       DateTime?
  pensionAiScore               Float?
  pensionAiVerdict             String?
  pensionAiReasoning           Json?
  pensionAiReviewedAt          DateTime?
  pensionAdminNotes            String?
  /// Accepted dog sizes for Pension: ["Petit", "Moyen", "Grand"] — set by admin at approval time
  pensionAcceptedSizes         Json?
  /// Inactivity tracking for published sitters with no availability
  /// Status: null (ok) | "nudge_sent" | "warning_1" | "warning_2" | "suspended"
  inactivityStatus             String?
  /// When the first "add availability" email was sent
  inactivityNudgeAt            DateTime?
  /// When warning 1 was sent (4-5 days after nudge)
  inactivityWarning1At         DateTime?
  /// When warning 2 was sent (3-4 days after warning 1)
  inactivityWarning2At         DateTime?
  /// When the account was suspended
  inactivitySuspendedAt        DateTime?
  /// @deprecated — kept for backward compat during migration. Use neuteredRequired instead.
  acceptanceCriteria           Json?
  /// OPAn art.101 certificate for sitters accepting >5 dogs simultaneously
  /// Status: null | "not_submitted" | "pending" | "approved" | "rejected"
  maxDogsCertVerifStatus       String?
  /// R2 key of the uploaded document (FSIFP attestation or cantonal authorization)
  maxDogsCertPhotoKey          String?
  maxDogsCertSubmittedAt       DateTime?
  maxDogsCertReviewedAt        DateTime?
  maxDogsCertAdminNotes        String?
  /// Weighted-places capacity model (replaces old per-size counters)
  /// Total capacity in "places" (small=1, medium=2, large=3). Range: 1–15.
  capacityPlaces               Int                                 @default(3)
  acceptsSmall                 Boolean                             @default(true)
  acceptsMedium                Boolean                             @default(true)
  acceptsLarge                 Boolean                             @default(true)
  /// Require neutered/spayed dogs
  neuteredRequired             Boolean                             @default(false)
  contractAmendmentAcceptances SitterContractAmendmentAcceptance[]
  user                         User                                @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationAccessLogs       VerificationAccessLog[]

  @@index([published])
  @@index([city])
  @@index([postalCode])
  @@index([verificationStatus])
  @@index([pensionVerifStatus])
}

model VerificationAccessLog {
  id               String        @id @default(cuid())
  sitterProfileId  String
  sitterId         String
  action           String
  fileKey          String?
  adminClerkUserId String?
  userAgent        String?
  createdAt        DateTime      @default(now())
  sitterProfile    SitterProfile @relation(fields: [sitterProfileId], references: [id], onDelete: Cascade)

  @@index([sitterProfileId, createdAt])
  @@index([sitterId, createdAt])
}

model ContractAmendment {
  id          String                              @id @default(cuid())
  title       String
  content     String
  version     String                              @unique
  isActive    Boolean                             @default(false)
  activatedAt DateTime?
  createdAt   DateTime                            @default(now())
  updatedAt   DateTime                            @updatedAt
  status      ContractAmendmentStatus             @default(INACTIVE)
  acceptances SitterContractAmendmentAcceptance[]

  @@index([status, createdAt])
  @@index([isActive, createdAt])
  @@index([createdAt])
}

model ServiceCost {
  id                      String                 @id @default(cuid())
  name                    String
  type                    ServiceCostType
  costType                ServiceCostBillingType
  monthlyCost             Float
  notes                   String?
  active                  Boolean                @default(true)
  estimatedCostPerBooking Float?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@index([active, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
}

model SitterContractAmendmentAcceptance {
  id               String            @id @default(cuid())
  amendmentId      String
  sitterProfileId  String
  amendmentVersion String
  amendmentTitle   String
  amendmentContent String
  acceptedAt       DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  amendment        ContractAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)
  sitterProfile    SitterProfile     @relation(fields: [sitterProfileId], references: [id], onDelete: Cascade)

  @@unique([amendmentId, sitterProfileId])
  @@index([sitterProfileId, acceptedAt])
  @@index([amendmentId, acceptedAt])
}

model Booking {
  id                         String                @id @default(cuid())
  userId                     String
  sitterId                   String
  status                     BookingStatus         @default(PENDING_PAYMENT)
  amount                     Int
  currency                   String                @default("chf")
  platformFeeAmount          Int
  stripeSessionId            String?
  stripePaymentIntentId      String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  service                    String?
  startDate                  DateTime?
  endDate                    DateTime?
  message                    String?
  canceledAt                 DateTime?
  archivedAt                 DateTime?
  deletedAt                  DateTime?
  refundedAt                 DateTime?
  stripeRefundId             String?
  stripeApplicationFeeAmount Int                   @default(0)
  stripeTransferId           String?
  reviewRequestEmailSentAt   DateTime?
  endAt                      DateTime?
  serviceType                ServiceType?
  startAt                    DateTime?
  stripeChargeId             String?
  stripeProcessingFeeAmount  Int                   @default(0)
  sitterPayoutAmount         Int?
  payoutReleasedAt           DateTime?
  lastMinuteSmsSentAt        DateTime?
  payoutMethod               BookingPayoutMethod   @default(STRIPE)
  payoutStatus               BookingPayoutStatus   @default(PENDING)
  paidAt                     DateTime?
  locationMode               String?
  travelDistanceKm           Float?
  travelFeeAmount            Int?
  ownerLat                   Float?
  ownerLng                   Float?
  ownerAddress               String?
  /// Dog profile selected by the owner at booking time
  dogProfileId               String?
  /// Owner phone number shared with the sitter
  ownerPhone                 String?
  /// Additional dog profile IDs (JSON array of strings) when multiple dogs are booked
  additionalDogProfileIds    String?
  selectedDog                DogProfile?           @relation(fields: [dogProfileId], references: [id])
  sitter                     User                  @relation("SitterBookings", fields: [sitterId], references: [sitterId])
  user                       User                  @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)
  financeEvents              BookingFinanceEvent[]
  conversations              Conversation[]        @relation("BookingConversations")
  review                     Review?

  @@index([userId])
  @@index([sitterId])
  @@index([dogProfileId])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
}

model BookingFinanceEvent {
  id                    String               @id @default(cuid())
  bookingId             String
  eventType             String
  message               String
  payoutMethod          BookingPayoutMethod?
  payoutStatus          BookingPayoutStatus?
  amount                Int?
  currency              String?
  stripeChargeId        String?
  stripeTransferId      String?
  stripePaymentIntentId String?
  metadata              Json?
  actorType             FinanceActorType?
  actorId               String?
  createdAt             DateTime             @default(now())
  booking               Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([eventType, createdAt])
  @@index([actorType, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  ownerId   String
  sitterId  String
  rating    Int
  comment   String?
  anonymous Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  owner     User     @relation("ReviewOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sitter    User     @relation("ReviewSitter", fields: [sitterId], references: [sitterId])

  @@index([sitterId, createdAt])
  @@index([ownerId, createdAt])
}

model Availability {
  id          String   @id @default(cuid())
  sitterId    String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  dateKey     String
  sitter      User     @relation("SitterAvailabilities", fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@unique([sitterId, dateKey])
  @@index([sitterId, dateKey])
}

model AvailabilityRule {
  id          String             @id @default(cuid())
  sitterId    String
  dayOfWeek   Int
  startMin    Int
  endMin      Int
  status      AvailabilityStatus
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  serviceType ServiceType
  sitter      User               @relation(fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@index([sitterId, serviceType, dayOfWeek])
  @@index([sitterId, serviceType])
}

model AvailabilityException {
  id          String             @id @default(cuid())
  sitterId    String
  date        DateTime           @db.Date
  startMin    Int
  endMin      Int
  status      AvailabilityStatus
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  serviceType ServiceType
  sitter      User               @relation(fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@index([sitterId, serviceType, date])
  @@index([sitterId, serviceType])
}

model AvailabilityAuditLog {
  id             String       @id @default(cuid())
  sitterId       String
  actorUserId    String
  action         String
  serviceType    ServiceType?
  dateKey        String?
  payloadSummary Json?
  createdAt      DateTime     @default(now())

  @@index([sitterId, createdAt])
  @@index([sitterId, serviceType, createdAt])
}

model ServiceConfig {
  id                String      @id @default(cuid())
  sitterId          String
  serviceType       ServiceType
  enabled           Boolean     @default(true)
  slotStepMin       Int
  minDurationMin    Int
  maxDurationMin    Int
  leadTimeMin       Int
  bufferBeforeMin   Int
  bufferAfterMin    Int
  overnightRequired Boolean     @default(false)
  checkInStartMin   Int?
  checkInEndMin     Int?
  checkOutStartMin  Int?
  checkOutEndMin    Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  lastMinuteEnabled Boolean     @default(false)
  sitter            User        @relation(fields: [sitterId], references: [sitterId], onDelete: Cascade)

  @@unique([sitterId, serviceType])
  @@index([sitterId])
  @@index([serviceType])
}

model Conversation {
  id                 String      @id @default(cuid())
  ownerId            String
  sitterId           String
  bookingId          String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  /// Dog selected by the owner as the subject of this conversation.
  dogProfileId       String?
  /// Set when owner pins the conversation; null = not pinned.
  pinnedAt           DateTime?
  /// Set when owner archives the conversation; null = not archived.
  archivedAt         DateTime?
  /// Soft-delete: set when owner deletes the conversation; null = visible.
  deletedAt          DateTime?
  booking            Booking?    @relation("BookingConversations", fields: [bookingId], references: [id])
  selectedDog        DogProfile? @relation(fields: [dogProfileId], references: [id])
  owner              User        @relation("OwnerConversations", fields: [ownerId], references: [id], onDelete: Cascade)
  sitter             User        @relation("SitterConversations", fields: [sitterId], references: [sitterId])
  messages           Message[]

  @@unique([ownerId, sitterId])
  @@index([ownerId])
  @@index([sitterId])
  @@index([bookingId])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Immutable audit trail for legal / dispute purposes.
/// Records every critical action on the platform with actor, target and timestamp.
/// Never delete rows — only append. No PII in metadata (use IDs only).
model AuditLog {
  id         String   @id @default(cuid())
  /// e.g. "booking.created", "booking.paid", "booking.cancelled",
  /// "sitter.approved", "sitter.rejected", "account.deleted"
  action     String
  /// "admin" | "user" | "system" | "stripe"
  actorType  String
  /// Clerk user ID (admin/user), "system" or "stripe"
  actorId    String?
  /// Primary key of the affected entity (booking ID, user ID, etc.)
  targetId   String?
  /// "BOOKING" | "USER" | "SITTER_PROFILE" | "APPLICATION"
  targetType String?
  /// Additional context: amounts (in cents), old/new status, payment intent ID…
  /// Never store email, name, phone or other PII here.
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetId, targetType])
  @@index([actorId, createdAt])
}

/// Singleton row `id = "global"` — platform-wide toggles (maintenance, etc.).
model PlatformSettings {
  id                 String   @id
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Persistent memory for autonomous agents (Maestro & sub-agents).
/// Stores conversation history, context, and state between runs.
model AgentMemory {
  id         String   @id @default(cuid())
  /// Agent name: "maestro", "booking_agent", "dispo_agent", "payment_agent"…
  agentName  String
  /// Session ID to group related interactions
  sessionId  String
  /// Role: "system" | "user" | "assistant" | "tool_call" | "tool_result"
  role       String
  /// The actual message content (JSON stringified for complex objects)
  content    String
  /// Token count for context window management
  tokenCount Int      @default(0)
  /// Metadata for filtering (bookingId, sitterId, userId, etc.)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([agentName, sessionId, createdAt])
  @@index([agentName, createdAt])
  @@index([sessionId, createdAt])
}

/// Logs every action taken by an autonomous agent. Append only.
model AgentLog {
  id         String   @id @default(cuid())
  /// "maestro" | "booking_agent" | "dispo_agent" | "payment_agent" | "notification_agent" | "supervision_agent"
  agentName  String
  /// "webhook_received" | "intent_determined" | "sub_agent_called" | "api_call" | "error" | "success"
  actionType String
  /// What the agent did (human readable)
  summary    String
  /// Full details (request, response, error stack…)
  details    Json?
  /// Related entities (booking ID, user ID, sitter ID…)
  targetId   String?
  /// Duration in ms
  durationMs Int?
  /// Status: "success" | "error" | "running"
  status     String   @default("success")
  createdAt  DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([actionType, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

/// Tracks scheduled or running tasks for autonomous agents.
model AgentTask {
  id           String    @id @default(cuid())
  /// "maestro" | "booking_agent" | "dispo_agent" | …
  agentName    String
  /// "scheduled" | "running" | "completed" | "failed" | "cancelled"
  status       String    @default("scheduled")
  /// Human readable task description
  title        String
  /// Full task definition / parameters
  payload      Json?
  /// Result of the task execution
  result       Json?
  /// Error message if failed
  errorMessage String?
  /// How many times it has been retried
  retryCount   Int       @default(0)
  /// Max retries before marking as failed
  maxRetries   Int       @default(3)
  /// When the task should be executed
  scheduledAt  DateTime?
  /// When the task started
  startedAt    DateTime?
  /// When the task completed/failed
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([agentName, status, scheduledAt])
  @@index([status, scheduledAt])
  @@index([createdAt])
}

/// Dog profile belonging to an owner. One owner can have multiple dogs.
/// conversations field: conversations where this dog was selected as the subject.
model DogProfile {
  id                 String         @id @default(cuid())
  userId             String
  name               String
  breed              String?
  birthYear          Int?
  weightKg           Float?
  medications        String?
  allergies          String?
  vetContact         String?
  behaviorNotes      String?
  feedingNotes       String?
  isDefault          Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  photoUrl           String?
  sitterInstructions String?
  /// Whether the dog is neutered/spayed — used to validate sitter acceptance criteria
  neutered           Boolean?
  /// Sex of the dog — required to opt into the breeding-match feature.
  sex                DogSex?
  bookings           Booking[]
  conversations      Conversation[]
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  matingProfile      MatingProfile?

  @@index([userId])
}

/// Opt-in breeding profile for a dog ("Tinder for dogs"). A dog is only
/// discoverable in the swipe deck when `enabled` is true. Kept 1:1 with
/// DogProfile so the hot DogProfile row stays lean and disabling/erasing is a
/// single-row delete.
model MatingProfile {
  id              String     @id @default(cuid())
  dogProfileId    String     @unique
  /// Denormalised owner id (== DogProfile.userId) for cheap "exclude my own dogs" filters.
  userId          String
  enabled         Boolean    @default(false)
  goal            MatingGoal @default(EXPLORING)
  bio             String?    @db.Text
  /// Canton / region text — v1 distance proxy (owners are not geocoded).
  region          String?
  /// Set when the owner ticks the single legal-compliance checkbox.
  acceptedTermsAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  dog        DogProfile @relation(fields: [dogProfileId], references: [id], onDelete: Cascade)
  swipesMade Swipe[]    @relation("SwiperMating")
  swipesGot  Swipe[]    @relation("TargetMating")
  matchesA   Match[]    @relation("MatchDogA")
  matchesB   Match[]    @relation("MatchDogB")

  @@index([userId])
  @@index([enabled])
}

/// One directed swipe from a dog's mating profile onto another's.
model Swipe {
  id          String         @id @default(cuid())
  swiperDogId String
  targetDogId String
  direction   SwipeDirection
  createdAt   DateTime       @default(now())

  swiper MatingProfile @relation("SwiperMating", fields: [swiperDogId], references: [id], onDelete: Cascade)
  target MatingProfile @relation("TargetMating", fields: [targetDogId], references: [id], onDelete: Cascade)

  @@unique([swiperDogId, targetDogId])
  @@index([targetDogId, direction])
  @@index([swiperDogId])
}

/// A mutual LIKE between two mating profiles. Canonical pair: dogAId < dogBId.
model Match {
  id         String    @id @default(cuid())
  dogAId     String
  dogBId     String
  createdAt  DateTime  @default(now())
  closedAt   DateTime?
  closedById String?

  dogA   MatingProfile @relation("MatchDogA", fields: [dogAId], references: [id], onDelete: Cascade)
  dogB   MatingProfile @relation("MatchDogB", fields: [dogBId], references: [id], onDelete: Cascade)
  thread MatchThread?

  @@unique([dogAId, dogBId])
  @@index([dogAId])
  @@index([dogBId])
}

/// Dedicated owner↔owner chat for a match (the existing Conversation model is
/// owner↔sitter only and cannot be reused here).
model MatchThread {
  id                 String    @id @default(cuid())
  matchId            String    @unique
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  match    Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages MatchMessage[]

  @@index([lastMessageAt])
}

model MatchMessage {
  id        String    @id @default(cuid())
  threadId  String
  senderId  String
  body      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  thread MatchThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User        @relation("MatchMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

model LeadMagnet {
  id              String    @id @default(cuid())
  email           String    @unique
  source          String    @default("homepage_banner")
  capturedAt      DateTime  @default(now())
  prenom          String?
  nurturingStep   Int       @default(0)
  lastNurturingAt DateTime?
  unsubscribed    Boolean   @default(false)

  @@index([nurturingStep, capturedAt])
  @@index([nurturingStep, lastNurturingAt])
}

model ScheduledEmail {
  id        String    @id @default(cuid())
  userId    String
  email     String
  type      String
  sendAfter DateTime
  sent      Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([sent, sendAfter])
}

model AgentConfig {
  id           String   @id @default(cuid())
  slug         String   @unique
  label        String
  description  String
  active       Boolean  @default(true)
  cronSchedule String?
  parameters   Json     @default("{}")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/// Native push tokens for iOS (APNs) and Android (FCM), used by the Capacitor app.
/// Distinct from PushSubscription (which is the web push / VAPID registration).
model NativePushToken {
  id            String             @id @default(cuid())
  userId        String
  /// "ios" for APNs, "android" for FCM
  platform      NativePushPlatform
  /// APNs device token (hex string) or FCM registration token
  token         String             @unique
  /// Bundle identifier (helps with multi-env: dev/staging/prod APNs sandbox)
  bundleId      String?
  /// Helps identify dead/invalid tokens after 410 Gone / NotRegistered errors
  invalidatedAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@map("native_push_tokens")
}

enum NativePushPlatform {
  ios
  android
}

/// Append-only audit of every transactional email the platform sends.
/// Populated by `lib/email/sendEmail.ts` on every call (success OR failure),
/// so the admin can answer "did Sonia really receive a suspension warning
/// on Tuesday at 3pm?" without grepping Vercel logs or Resend's dashboard.
///
/// PII rules : `to` and `subject` are stored verbatim (we need them to
/// search). `metadata` MUST stay PII-free — IDs only.
model EmailLog {
  id           String   @id @default(cuid())
  to           String
  fromAddress  String?
  subject      String
  /// Logical template name set by the caller, e.g. "inactivity-warning-1",
  /// "reset-password", "booking-confirmed". Optional but strongly preferred —
  /// it's what makes the admin page filterable.
  templateName String?
  /// Where the email was triggered from, e.g. "cron:inactivity-check",
  /// "api:auth/forgot-password", "agent:relance-owners". Free text but
  /// kebab-case prefix convention.
  context      String?
  /// "sent" when the provider returned 2xx, "failed" on any throw, "skipped"
  /// when the caller pre-emptively decided not to send (rare).
  status       String
  /// Provider used: "resend" | "smtp" | "log" (dev fallback).
  mode         String?
  /// Provider-assigned message id (Resend). Useful for cross-checking with
  /// the Resend dashboard or bounce webhooks.
  messageId    String?
  /// When status=failed, the error message. Truncated at 500 chars.
  errorMessage String?
  /// FK-like reference to User.id when the recipient is a known account.
  /// Not a hard FK to keep this table writable even if the user is later
  /// deleted (audit must survive deletions).
  targetUserId String?
  /// Small, PII-free extra context. e.g. { bookingId, sitterId, stage }.
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([to, createdAt])
  @@index([templateName, createdAt])
  @@index([status, createdAt])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
}

