{
  "name": "dogshift",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build",
    "vercel-build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test --experimental-strip-types --experimental-specifier-resolution=node 'tests/**/*.test.ts'",
    "test:watch": "node --test --watch --experimental-strip-types --experimental-specifier-resolution=node 'tests/**/*.test.ts'",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:deploy:prod": "prisma migrate deploy && prisma generate",
    "generate-invite-codes": "node scripts/generate-invite-codes.mjs",
    "postinstall": "prisma generate",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "ship": "bash scripts/ship.sh",
    "test:e2e": "playwright test"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --max-warnings=0 --no-warn-ignored",
    "*.{js,jsx,mjs,cjs}": "eslint --fix --max-warnings=0 --no-warn-ignored"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.987.0",
    "@aws-sdk/s3-request-presigner": "^3.987.0",
    "@capacitor/android": "^7.6.5",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@capacitor/push-notifications": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@dnd-kit/core": "^6.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^0.5.1",
    "@react-email/render": "^1.2.1",
    "@sentry/nextjs": "^10.48.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.6.0",
    "@types/web-push": "^3.6.4",
    "@vercel/functions": "^3.5.0",
    "@vonage/server-sdk": "^3.27.0",
    "ai": "^6.0.170",
    "bcryptjs": "^2.4.3",
    "core-js": "^3.49.0",
    "exifr": "^7.1.3",
    "jspdf": "^2.5.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "mapbox-gl": "^3.17.0",
    "maplibre-gl": "^5.14.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.2",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "stripe": "^20.1.0",
    "svix": "^1.92.2",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.1"
  },
  "overrides": {
    "dompurify": ">=3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
